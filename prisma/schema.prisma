generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WORKER
}

enum ProductUnit {
  KG
  UNIT
}

enum CostNature {
  FIXED
  VARIABLE
}

enum CostScope {
  COMPANY
  SHOP
  PLANTATION
}

enum DailyCloseStatus {
  OPEN
  CLOSED
}

model Company {
  id           String        @id @default(cuid())
  name         String
  document     String?       @unique
  ownerName    String
  ownerEmail   String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  users        User[]
  shops        Shop[]
  plantations  Plantation[]
  costs        Cost[]
  stockMoves   StockMovement[]
  dailyCloses  DailyClose[]
}

model User {
  id           String               @id @default(cuid())
  companyId    String
  shopId       String?
  name         String
  email        String               @unique
  passwordHash String
  role         UserRole             @default(WORKER)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shop         Shop?                @relation(fields: [shopId], references: [id], onDelete: SetNull)
  shopLinks    UserShopAssignment[]
  createdDailyCloses DailyClose[]   @relation("DailyCloseCreatedBy")

  @@index([companyId])
  @@index([shopId])
}

model Shop {
  id           String               @id @default(cuid())
  companyId    String
  name         String
  code         String?
  city         String?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workers      User[]
  workerLinks  UserShopAssignment[]
  stockMoves   StockMovement[]
  dailyCloses  DailyClose[]
  costs        Cost[]

  @@unique([companyId, name])
  @@index([companyId])
}

model UserShopAssignment {
  userId    String
  shopId    String
  createdAt DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([userId, shopId])
  @@index([shopId])
}

model Plantation {
  id           String      @id @default(cuid())
  companyId    String
  name         String
  location     String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockMoves   StockMovement[]
  costs        Cost[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id                String        @id @default(cuid())
  name              String        @unique
  unit              ProductUnit
  suggestedPrice    Decimal       @db.Decimal(12, 2)
  sku               String?       @unique
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  stockMoves        StockMovement[]
  dailyCloseItems   DailyCloseItem[]
}

model StockMovement {
  id              String      @id @default(cuid())
  companyId       String
  productId       String
  plantationId    String?
  shopId          String?
  quantity        Decimal     @db.Decimal(12, 3)
  unitCost        Decimal?    @db.Decimal(12, 2)
  movementDate    DateTime    @default(now())
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product         Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  plantation      Plantation? @relation(fields: [plantationId], references: [id], onDelete: SetNull)
  shop            Shop?       @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([companyId, movementDate])
  @@index([shopId, movementDate])
  @@index([plantationId, movementDate])
}

model DailyClose {
  id              String             @id @default(cuid())
  companyId       String
  shopId          String
  closeDate       DateTime
  openingAmount   Decimal            @default(0) @db.Decimal(12, 2)
  replenishment   Decimal            @default(0) @db.Decimal(12, 2)
  losses          Decimal            @default(0) @db.Decimal(12, 2)
  sales           Decimal            @default(0) @db.Decimal(12, 2)
  finalBalance    Decimal            @default(0) @db.Decimal(12, 2)
  status          DailyCloseStatus   @default(OPEN)
  createdById     String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shop            Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy       User?              @relation("DailyCloseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items           DailyCloseItem[]

  @@unique([shopId, closeDate])
  @@index([companyId, closeDate])
}

model DailyCloseItem {
  id              String      @id @default(cuid())
  dailyCloseId    String
  productId       String?
  kind            String
  amount          Decimal     @db.Decimal(12, 2)
  quantity        Decimal?    @db.Decimal(12, 3)
  createdAt       DateTime    @default(now())

  dailyClose      DailyClose  @relation(fields: [dailyCloseId], references: [id], onDelete: Cascade)
  product         Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([dailyCloseId])
}

model Cost {
  id              String      @id @default(cuid())
  companyId       String
  shopId          String?
  plantationId    String?
  name            String
  nature          CostNature
  scope           CostScope   @default(COMPANY)
  amount          Decimal     @db.Decimal(12, 2)
  dueDate         DateTime?
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean     @default(true)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shop            Shop?       @relation(fields: [shopId], references: [id], onDelete: SetNull)
  plantation      Plantation? @relation(fields: [plantationId], references: [id], onDelete: SetNull)

  @@index([companyId, nature, scope])
  @@index([shopId])
  @@index([plantationId])
}
